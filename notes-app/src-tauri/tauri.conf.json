{
  "productName": "typos",
  "version": "0.1.0",
  "identifier": "com.typos.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "typos",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": ["binaries/typst"],
    "resources": {
      "../../notes-framework/typst.toml": "packages/local/notes/0.1.0/typst.toml",
      "../../notes-framework/src/*": "packages/local/notes/0.1.0/src/"
    }
  },
  "plugins": {}
}
